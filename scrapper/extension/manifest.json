{
  "manifest_version": 3,
  "name": "LockIn",
  "version": "0.1.0",
  "description": "Scrape YouTube tiles, classify them against a local profile, and block irrelevant content in-page.",
  "permissions": ["activeTab", "scripting", "storage", "alarms", "tabs", "permissions"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "LockIn",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
